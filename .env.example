# ============================================================
# NOMMAD — Artist OS — env template
# Copie para .env.local e preencha. Nunca comite .env.local.
# ============================================================

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ---- Anthropic (agentes) ----
ANTHROPIC_API_KEY=
# Modelos por agente (override opcional)
ANTHROPIC_MODEL_CLEANER=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_CLASSIFIER=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_ANALYST=claude-sonnet-4-6
ANTHROPIC_MODEL_STRATEGIST=claude-sonnet-4-6
ANTHROPIC_MODEL_RESPONSE=claude-sonnet-4-6
ANTHROPIC_MODEL_MISSION=claude-sonnet-4-6
ANTHROPIC_MODEL_CHECKIN=claude-sonnet-4-6
ANTHROPIC_MODEL_PSYCHO=claude-opus-4-7
ANTHROPIC_MODEL_BRAIN=claude-opus-4-7

# ---- Transcrição ----
GROQ_API_KEY=
# fallback
OPENAI_API_KEY=

# ---- Stripe ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID_PRO=          # R$ 500/mês
STRIPE_PRICE_ID_PREMIUM=      # Pro + Psycho Agent

# ---- Observabilidade (opcional) ----
SENTRY_DSN=
POSTHOG_KEY=

# ---- Feature flags ----
FF_PSYCHO_AGENT=false
FF_RELEASE_SYSTEM=true
FF_BRAIN_PARALLEL=true
