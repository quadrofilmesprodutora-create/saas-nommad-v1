# Worker identity
WORKER_ID=00000000-0000-4000-8000-000000000001
WORKER_NAME=studio-pc

# HMAC secret — MESMA string do Vercel (WORKER_SHARED_SECRET)
WORKER_SHARED_SECRET=change-me-32-bytes-random-string

# ComfyUI rodando local
COMFY_URL=http://127.0.0.1:8188

# Supabase (service role pra bypassar RLS e subir no Storage)
SUPABASE_URL=https://<projeto>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_BUCKET=design-assets

# Base da API Vercel pra heartbeat
VERCEL_API_BASE=https://nommad.vercel.app

# Porta local do worker (exposta via Tailscale Funnel)
WORKER_PORT=7777

# Optional: caminho do Real-ESRGAN (fica em models/upscale_models do ComfyUI)
UPSCALE_ENABLED=true
